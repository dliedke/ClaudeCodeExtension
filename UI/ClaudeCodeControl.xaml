<UserControl x:Class="ClaudeCodeVS.ClaudeCodeControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wf="clr-namespace:System.Windows.Forms.Integration;assembly=WindowsFormsIntegration"
             xmlns:vsshell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="400"
             Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
             Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}">

	<UserControl.Resources>
		<!-- Single border GroupBox style -->
		<Style x:Key="SingleBorderGroupBoxStyle" TargetType="GroupBox">
			<Setter Property="Padding" Value="3"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="GroupBox">
						<Grid>
							<Grid.RowDefinitions>
								<RowDefinition Height="Auto"/>
								<RowDefinition Height="*"/>
							</Grid.RowDefinitions>

							<!-- Border around content -->
							<Border Grid.Row="0" Grid.RowSpan="2"
							        BorderBrush="{TemplateBinding BorderBrush}"
							        BorderThickness="{TemplateBinding BorderThickness}"
							        Background="{TemplateBinding Background}"
							        CornerRadius="4">
							</Border>

							<!-- Header with background to cover border -->
							<Border Grid.Row="0"
							        Background="{TemplateBinding Background}"
							        Margin="8,0,0,0"
							        HorizontalAlignment="Left">
								<ContentPresenter ContentSource="Header"
								                  RecognizesAccessKey="True"
								                  Margin="4,0"/>
							</Border>

							<!-- Content -->
							<ContentPresenter Grid.Row="1"
							                  Margin="{TemplateBinding Padding}"/>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Adaptive button style for light/dark theme -->
		<Style x:Key="AdaptiveButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
			<Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
			<Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="8,5"/>
			<Setter Property="Height" Value="30"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Focusable" Value="False"/>
			<Setter Property="SnapsToDevicePixels" Value="True"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsMouseOver" Value="True">
								<Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarHoverOverSelectedKey}}"/>
								<Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}"/>
							</Trigger>
							<Trigger Property="IsPressed" Value="True">
								<Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedKey}}"/>
								<Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.CommandBarSelectedBorderKey}}"/>
							</Trigger>
							<Trigger Property="IsEnabled" Value="False">
								<Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
								<Setter Property="Foreground" Value="{DynamicResource {x:Static vsshell:VsBrushes.GrayTextKey}}"/>
								<Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Small "chip" for attached files -->
		<Style x:Key="ChipBorder" TargetType="Border">
			<Setter Property="Background" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"/>
			<Setter Property="CornerRadius" Value="10"/>
			<Setter Property="Padding" Value="5,1"/>
			<Setter Property="Margin" Value="0,2,4,0"/>
			<Setter Property="BorderBrush" Value="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Height" Value="22"/>
		</Style>

		<Style x:Key="ChipRemoveButton" TargetType="Button" BasedOn="{StaticResource AdaptiveButtonStyle}">
			<Setter Property="Width" Value="14"/>
			<Setter Property="Height" Value="14"/>
			<Setter Property="Padding" Value="0"/>
			<Setter Property="Margin" Value="4,0,0,0"/>
			<Setter Property="Content" Value="×"/>
			<Setter Property="FontWeight" Value="Bold"/>
			<Setter Property="FontSize" Value="10"/>
		</Style>

		<!-- Small button style for provider selection -->
		<Style x:Key="ProviderButtonStyle" TargetType="Button" BasedOn="{StaticResource AdaptiveButtonStyle}">
			<Setter Property="FontSize" Value="10"/>
			<Setter Property="Height" Value="22"/>
			<Setter Property="Padding" Value="8,3"/>
			<Setter Property="Margin" Value="2"/>
			<Setter Property="MinWidth" Value="80"/>
		</Style>

		<!-- Icon button style (slightly dimmed for icon-only buttons) -->
		<Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource AdaptiveButtonStyle}">
			<Setter Property="Opacity" Value="0.93"/>
		</Style>

		<!-- ============ Effort pill slider (VS Code-like) ============ -->
		<!-- Filled (left of thumb) portion: blue, turns purple at the Max stop -->
		<Style x:Key="EffortFillButtonStyle" TargetType="RepeatButton">
			<Setter Property="OverridesDefaultStyle" Value="True"/>
			<Setter Property="Focusable" Value="False"/>
			<Setter Property="IsTabStop" Value="False"/>
			<Setter Property="Background" Value="#1C8AE0"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RepeatButton">
						<Border Background="{TemplateBinding Background}" CornerRadius="9"/>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<!-- Top (Max) stop turns purple, like the VS Code "ultracode" cap -->
				<DataTrigger Binding="{Binding Value, RelativeSource={RelativeSource AncestorType={x:Type Slider}}}" Value="5">
					<Setter Property="Background" Value="#9B7BD4"/>
				</DataTrigger>
			</Style.Triggers>
		</Style>

		<!-- Unfilled (right of thumb) portion: transparent so the gray track shows through -->
		<Style x:Key="EffortTransparentButtonStyle" TargetType="RepeatButton">
			<Setter Property="OverridesDefaultStyle" Value="True"/>
			<Setter Property="Focusable" Value="False"/>
			<Setter Property="IsTabStop" Value="False"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RepeatButton">
						<Border Background="Transparent"/>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- White circular thumb -->
		<Style x:Key="EffortThumbStyle" TargetType="Thumb">
			<Setter Property="OverridesDefaultStyle" Value="True"/>
			<Setter Property="Focusable" Value="False"/>
			<Setter Property="Width" Value="16"/>
			<Setter Property="Height" Value="16"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Thumb">
						<Ellipse Fill="#F5F5F5" Stroke="#33000000" StrokeThickness="1"/>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<Style x:Key="EffortSliderStyle" TargetType="Slider">
			<Setter Property="Minimum" Value="0"/>
			<Setter Property="Maximum" Value="5"/>
			<Setter Property="SmallChange" Value="1"/>
			<Setter Property="LargeChange" Value="1"/>
			<Setter Property="TickFrequency" Value="1"/>
			<Setter Property="IsSnapToTickEnabled" Value="True"/>
			<Setter Property="Width" Value="175"/>
			<Setter Property="Height" Value="22"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Slider">
						<Grid VerticalAlignment="Center" Height="18">
							<!-- Track background pill. Semi-transparent gray so it reads as a
							     subtle groove on both light and dark menu backgrounds. -->
							<Border CornerRadius="9" Background="#80808080"/>
							<!-- Six position dots (sit under the fill/thumb) -->
							<UniformGrid Rows="1" Columns="6" Margin="11,0">
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
								<Ellipse Width="4" Height="4" Fill="#80606060" HorizontalAlignment="Center" VerticalAlignment="Center"/>
							</UniformGrid>
							<Track x:Name="PART_Track">
								<Track.DecreaseRepeatButton>
									<RepeatButton Style="{StaticResource EffortFillButtonStyle}" Command="Slider.DecreaseLarge"/>
								</Track.DecreaseRepeatButton>
								<Track.Thumb>
									<Thumb Style="{StaticResource EffortThumbStyle}"/>
								</Track.Thumb>
								<Track.IncreaseRepeatButton>
									<RepeatButton Style="{StaticResource EffortTransparentButtonStyle}" Command="Slider.IncreaseLarge"/>
								</Track.IncreaseRepeatButton>
							</Track>
						</Grid>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>
	</UserControl.Resources>

	<Grid x:Name="MainGrid">
		<Grid.RowDefinitions>
			<RowDefinition Height="*" MinHeight="0"/>
			<RowDefinition Height="4"/>
			<RowDefinition Height="2*" MinHeight="0"/>
		</Grid.RowDefinitions>

		<!-- Top Section Container (Prompt area) -->
		<Grid x:Name="PromptSectionGrid" Grid.Row="0" Margin="6,6,6,0">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" MinHeight="80"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
				<RowDefinition Height="Auto"/>
			</Grid.RowDefinitions>

			<!-- Prompt Input Area -->
			<GroupBox x:Name="PromptGroupBox" Grid.Row="0"
                      Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                      BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                      BorderThickness="1"
                      Margin="0,0,0,2"
                      Style="{StaticResource SingleBorderGroupBoxStyle}">
				<GroupBox.Header>
					<TextBlock Text="Prompt / Paste Image" Opacity="0.93"/>
				</GroupBox.Header>
				<TextBox x:Name="PromptTextBox"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Mono"
                         Cursor="IBeam"
                         Background="{DynamicResource {x:Static vsshell:VsBrushes.WindowKey}}"
                         Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                         BorderBrush="Transparent"
                         BorderThickness="0"
                         AllowDrop="True"
                         PreviewDragOver="PromptTextBox_PreviewDragOver"
                         PreviewDrop="PromptTextBox_PreviewDrop"
                         KeyDown="PromptTextBox_KeyDown"
                         PreviewKeyDown="PromptTextBox_PreviewKeyDown"
                         TextChanged="PromptTextBox_TextChanged"
                         PreviewMouseWheel="PromptTextBox_PreviewMouseWheel">
					<TextBox.ContextMenu>
						<ContextMenu>
							<MenuItem Header="Cut" Command="ApplicationCommands.Cut" InputGestureText="Ctrl+X"
							          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
							<MenuItem Header="Copy" Command="ApplicationCommands.Copy" InputGestureText="Ctrl+C"
							          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
							<MenuItem Header="Paste" Command="ApplicationCommands.Paste" InputGestureText="Ctrl+V"
							          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
							<Separator/>
							<MenuItem Header="Select All" Command="ApplicationCommands.SelectAll" InputGestureText="Ctrl+A"
							          CommandTarget="{Binding PlacementTarget, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
							<Separator/>
							<MenuItem Header="Clear Prompt History" Click="ClearPromptHistoryMenuItem_Click"/>
						</ContextMenu>
					</TextBox.ContextMenu>
				</TextBox>
			</GroupBox>

			<!-- Resize grip at the bottom edge of the prompt box. Lets the user
			     drag the prompt area taller/shorter directly (drives the same
			     prompt/terminal split as MainGridSplitter). Shown only in the
			     default top/bottom layout; hidden in inverted/side-by-side. -->
			<Thumb x:Name="PromptResizeGrip" Grid.Row="0"
			       VerticalAlignment="Bottom" HorizontalAlignment="Stretch"
			       Height="6" Margin="0,0,0,2"
			       Cursor="SizeNS"
			       Visibility="Collapsed"
			       ToolTip="Drag to resize the prompt area"
			       DragDelta="PromptResizeGrip_DragDelta"
			       DragCompleted="PromptResizeGrip_DragCompleted">
				<Thumb.Template>
					<ControlTemplate TargetType="Thumb">
						<Border Background="Transparent">
							<Border Width="44" Height="3" CornerRadius="2"
							        VerticalAlignment="Center" HorizontalAlignment="Center"
							        Opacity="0.85"
							        Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"/>
						</Border>
					</ControlTemplate>
				</Thumb.Template>
			</Thumb>

			<!-- Controls row: [Send + Add Image] | [Restart (right-aligned)] -->
			<Grid x:Name="ControlsRow" Grid.Row="1" Margin="0,4,0,0" VerticalAlignment="Top">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="Auto"/>
					<ColumnDefinition Width="*"/>
					<ColumnDefinition Width="Auto"/>
				</Grid.ColumnDefinitions>

				<!-- Left cluster -->
				<StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Top">
					<!-- Send button (visible only when Send-with-Enter is off) -->
					<Button x:Name="SendPromptButton"
                            Content="▶"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="SendButton_Click"
                            Visibility="Collapsed"
                            ToolTip="Send Prompt to Code Agent"
                            Margin="0,0,6,0"/>

					<Button x:Name="AttachDropdownButton"
                            Content="📎"
                            Style="{StaticResource IconButtonStyle}"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            HorizontalAlignment="Left"
                            ToolTip="Attach / Insert Content"
                            Click="AttachDropdownButton_Click">
							<Button.ContextMenu>
								<ContextMenu x:Name="AttachContextMenu">
									<MenuItem Header="📎  Attach File..." x:Name="AttachFileMenuItem" Click="AttachFileMenuItem_Click"/>
									<MenuItem Header="📋  Insert Editor Selection" x:Name="InsertSelectionMenuItem" Click="GrabSelectionButton_Click"/>
									<!--
										Optional menu entry. Hidden by default. Set
										EnablePasteFromClipboardMenu = true in ClaudeCodeControl.UserInput.cs
										to expose it.
									-->
									<MenuItem Header="📥  Paste from Clipboard" x:Name="PasteFromClipboardMenuItem" Click="PasteFromClipboardMenuItem_Click" Visibility="Collapsed" ToolTip="When clipboard text is short it is inserted into the prompt directly. When it exceeds the truncation threshold it is saved to a temp file and attached, avoiding paste truncation."/>
								</ContextMenu>
							</Button.ContextMenu>
						</Button>
				</StackPanel>

                <!-- Right-aligned buttons (Restart + Model + Settings + Update) -->
				<StackPanel x:Name="RightButtonsPanel"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            Margin="6,0,0,0">


					<!--
						One-click toolbar buttons. All collapsed by default; RefreshToolbarLayout()
						shows the ones the user promoted (Settings → Toolbar) and removes the
						matching entries from the "⚙" menu. See ClaudeCodeControl.ProviderManagement.cs.
					-->
					<Button x:Name="UpdateAgentToolbarButton"
                            Content="🔄️"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="UpdateAgentButton_Click"
                            ToolTip="Update Code Agent"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<!-- Detach/attach uses the original vector icon (box + arrow); the arrow
					     direction flips with state in UpdateDetachButtonIcon. -->
					<Button x:Name="DetachToolbarButton"
                            Width="30"
                            Height="30"
                            Style="{StaticResource IconButtonStyle}"
                            Click="DetachTerminalButton_Click"
                            ToolTip="Detach Terminal to Separate Tab"
                            Visibility="Collapsed"
                            Margin="0,0,6,0">
						<Viewbox x:Name="DetachButtonIcon" Width="16" Height="14" Stretch="Uniform"/>
					</Button>

					<Button x:Name="RestartTerminalButton"
                            Content="♻️"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="RestartTerminalButton_Click"
                            ToolTip="Restart Code Agent"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<Button x:Name="ViewChangesToolbarButton"
                            Content="📄"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ViewChangesButton_Click"
                            ToolTip="View Changes"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<Button x:Name="SessionHistoryToolbarButton"
                            Content="📜"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="SessionHistoryButton_Click"
                            ToolTip="Session History"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<Button x:Name="ShowUsageToolbarButton"
                            Content="📊"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="ShowUsageViewMenuItem_Click"
                            ToolTip="Show Usage"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<Button x:Name="SetWorkingDirectoryToolbarButton"
                            Content="📁"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            Click="SetWorkingDirectoryMenuItem_Click"
                            ToolTip="Set Working Directory"
                            Visibility="Collapsed"
                            Margin="0,0,6,0"/>

					<!-- Tools dropdown: holds the configurable features the user did NOT promote to
					     their own toolbar button. Auto-hides when every feature is a button
					     (RefreshToolbarLayout). Keeps these features out of the ⚙ menu. -->
					<Button x:Name="ToolsDropdownButton"
                            Content="☰"
                            Width="30"
                            MinWidth="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            ToolTip="Tools"
                            Visibility="Collapsed"
                            Click="ToolsDropdownButton_Click"
                            Margin="0,0,6,0">
						<Button.ContextMenu>
							<ContextMenu x:Name="ToolsContextMenu" Opened="ToolsContextMenu_Opened">
								<MenuItem Header="🔄️  Update Code Agent" x:Name="UpdateAgentMenuItem" Click="UpdateAgentButton_Click"/>
								<MenuItem Header="♻️  Restart Code Agent" x:Name="RestartTerminalMenuItem" Click="RestartTerminalButton_Click"/>
								<MenuItem Header="⧉  Detach Terminal to Separate Tab" x:Name="DetachTerminalMenuItem" Click="DetachTerminalButton_Click"/>
								<MenuItem Header="📄  View Changes" x:Name="ViewChangesMenuItem" Click="ViewChangesButton_Click"/>
								<MenuItem Header="📜  Session History" x:Name="SessionHistoryViewMenuItem" Click="SessionHistoryButton_Click" Visibility="Collapsed"/>
								<MenuItem Header="📊  Show Usage" x:Name="ShowUsageViewMenuItem" Click="ShowUsageViewMenuItem_Click" IsCheckable="True" Visibility="Collapsed"/>
								<MenuItem Header="📁  Set Working Directory..." x:Name="SetWorkingDirectoryMenuItem" Click="SetWorkingDirectoryMenuItem_Click" ToolTip="Set a custom working directory (absolute or relative to solution). Leave empty for default behavior."/>
							</ContextMenu>
						</Button.ContextMenu>
					</Button>

					<Button x:Name="CustomCommandsButton"
                            Content="⚡"
                            Width="30"
                            Height="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            FontFamily="Consolas"
                            ToolTip="Custom Commands"
                            Visibility="Collapsed"
                            Click="CustomCommandsButton_Click"
                            Margin="0,0,6,0">
						<Button.ContextMenu>
							<ContextMenu x:Name="CustomCommandsContextMenu"/>
						</Button.ContextMenu>
					</Button>

					<Button x:Name="ModelDropdownButton"
                            Content="🤖"
                            Width="30"
                            Height="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            FontFamily="Consolas"
                            ToolTip="Model Selection"
                            Click="ModelDropdownButton_Click"
                            Margin="0,0,6,0">
						<Button.ContextMenu>
							<ContextMenu x:Name="ModelContextMenu" Opened="ModelContextMenu_Opened">
								<!-- Claude-specific items -->
								<MenuItem Header="Best - Fable 5, else latest Opus" x:Name="BestMenuItem" Click="BestMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Opus - Complex tasks" x:Name="OpusMenuItem" Click="OpusMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Sonnet - Everyday tasks" x:Name="SonnetMenuItem" Click="SonnetMenuItem_Click" IsCheckable="True" IsChecked="True"/>
								<MenuItem Header="Haiku - Easy tasks" x:Name="HaikuMenuItem" Click="HaikuMenuItem_Click" IsCheckable="True"/>
								<Separator/>
								<MenuItem Header="Opus Plan - Opus for planning, Sonnet for execution" x:Name="OpusPlanMenuItem" Click="OpusPlanMenuItem_Click" IsCheckable="True"/>
								<Separator x:Name="EffortSeparator"/>
								<MenuItem x:Name="EffortSliderMenuItem" StaysOpenOnClick="True">
									<MenuItem.Header>
										<StackPanel Margin="2,3" MinWidth="190">
											<TextBlock x:Name="EffortSliderLabel" Text="Effort (Auto)" Margin="0,0,0,5" FontWeight="SemiBold"/>
											<Slider x:Name="EffortSlider" Style="{StaticResource EffortSliderStyle}"
											        HorizontalAlignment="Left"
											        ValueChanged="EffortSlider_ValueChanged"
											        Thumb.DragStarted="EffortSlider_DragStarted"
											        Thumb.DragCompleted="EffortSlider_DragCompleted"/>
										</StackPanel>
									</MenuItem.Header>
								</MenuItem>
								<Separator x:Name="ClaudeAccountSeparator"/>
								<MenuItem Header="Change Account" x:Name="ChangeAccountMenuItem" Click="ChangeAccountMenuItem_Click"/>
								<MenuItem Header="Set Language" x:Name="SetLanguageMenuItem" Click="SetLanguageMenuItem_Click"/>
								<MenuItem Header="Install Caveman" x:Name="InstallCavemanMenuItem" Click="InstallCavemanMenuItem_Click" ToolTip="Install the Caveman plugin (JuliusBrussee/caveman) — ultra-compressed communication mode for Claude Code"/>
								<!-- Devin-specific items. The model entries are built dynamically from
								     ClaudeCodeSettings.DevinModels in ModelContextMenu_Opened and inserted
								     above this separator; the two items below are static. -->
								<Separator x:Name="DevinModelsSeparator"/>
								<MenuItem Header="Configure Models..." x:Name="DevinConfigureModelsMenuItem" Click="DevinConfigureModelsMenuItem_Click" ToolTip="Add, edit, remove, or reorder the Devin models shown in this menu."/>
							</ContextMenu>
						</Button.ContextMenu>
					</Button>
					<Button x:Name="MenuDropdownButton"
                            Content="⚙"
                            Width="30"
                            Height="30"
                            FontSize="14"
                            Style="{StaticResource IconButtonStyle}"
                            FontFamily="Consolas"
                            ToolTip="Code Agent Selection"
                            Click="MenuDropdownButton_Click"
                            Margin="0,0,6,0">
						<Button.ContextMenu>
							<ContextMenu x:Name="ProviderContextMenu" Opened="ProviderContextMenu_Opened">
								<MenuItem Header="Claude Code" x:Name="ClaudeCodeMenuItem" Click="ClaudeCodeMenuItem_Click" IsCheckable="True" IsChecked="True"/>
								<MenuItem Header="Claude Code (WSL)" x:Name="ClaudeCodeWSLMenuItem" Click="ClaudeCodeWSLMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Codex" x:Name="CodexNativeMenuItem" Click="CodexNativeMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Codex (WSL)" x:Name="CodexMenuItem" Click="CodexMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Cursor Agent" x:Name="CursorAgentNativeMenuItem" Click="CursorAgentNativeMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Cursor Agent (WSL)" x:Name="CursorAgentMenuItem" Click="CursorAgentMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Open Code" x:Name="OpenCodeMenuItem" Click="OpenCodeMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Devin" x:Name="DevinNativeMenuItem" Click="DevinNativeMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Devin (WSL)" x:Name="DevinMenuItem" Click="DevinMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="PI" x:Name="PiMenuItem" Click="PiMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Antigravity" x:Name="AntigravityMenuItem" Click="AntigravityMenuItem_Click" IsCheckable="True"/>
								<MenuItem Header="Reasonix" x:Name="ReasonixMenuItem" Click="ReasonixMenuItem_Click" IsCheckable="True"/>
								<Separator/>
								<MenuItem Header="Configure Visible Code Agents..." x:Name="ConfigureVisibleAgentsMenuItem" Click="ConfigureVisibleAgentsMenuItem_Click" ToolTip="Choose which code agents appear in this menu. The active agent always remains visible."/>
								<Separator x:Name="AutoOpenChangesSeparator"/>
								<MenuItem Header="Claude Code: Skip Permissions" x:Name="ClaudeDangerouslySkipPermissionsMenuItem" Click="ClaudeDangerouslySkipPermissionsMenuItem_Click" IsCheckable="True" ToolTip="When enabled, Claude Code starts with --dangerously-skip-permissions"/>
								<MenuItem Header="Codex: Approval Never" x:Name="CodexFullAutoMenuItem" Click="CodexFullAutoMenuItem_Click" IsCheckable="True" ToolTip="When enabled, Codex starts with --ask-for-approval never"/>
								<MenuItem Header="Cursor Agent: Yolo Mode" x:Name="CursorAgentAutoRunMenuItem" Click="CursorAgentAutoRunMenuItem_Click" IsCheckable="True" ToolTip="When enabled, Cursor Agent starts with --yolo to skip all approvals"/>
								<MenuItem Header="Devin: Dangerous Mode" x:Name="DevinDangerousModeMenuItem" Click="DevinDangerousModeMenuItem_Click" IsCheckable="True" ToolTip="When enabled, Devin starts with --permission-mode dangerous"/>
								<MenuItem Header="Antigravity: Skip Permissions" x:Name="AntigravityDangerouslySkipPermissionsMenuItem" Click="AntigravityDangerouslySkipPermissionsMenuItem_Click" IsCheckable="True" ToolTip="When enabled, Antigravity starts with --dangerously-skip-permissions"/>
								<Separator/>
								<MenuItem Header="Configure Custom Commands..." x:Name="ConfigureCustomCommandsMenuItem" Click="ConfigureCustomCommandsMenuItem_Click" ToolTip="Add, edit, or remove custom commands surfaced in the toolbar dropdown next to the agent menu."/>
								<MenuItem Header="Hide Prompt Input Box" x:Name="HidePromptPanelMenuItem" Click="HidePromptPanelMenuItem_Click" IsCheckable="True" ToolTip="Collapse the multi-line prompt box to give the terminal more vertical space. This menu, the model and provider buttons, and file chips stay reachable so you can turn it back on."/>
								<MenuItem Header="Settings..." x:Name="SettingsMenuItem" Click="SettingsMenuItem_Click" ToolTip="Open the consolidated settings dialog (layout, terminal type, theme, send behavior, auto-zoom, auto-open changes)."/>
								<Separator/>
								<MenuItem Header="About" x:Name="AboutMenuItem" Click="AboutMenuItem_Click"/>
							</ContextMenu>
						</Button.ContextMenu>
					</Button>
				</StackPanel>
			</Grid>

			<!-- File chips row -->
			<Grid x:Name="CheckboxRow" Grid.Row="2" Margin="0,4,0,2">
				<ScrollViewer VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalAlignment="Center">
					<WrapPanel x:Name="AttachedImagesPanel" />
				</ScrollViewer>
			</Grid>

			<!-- Inline Claude usage mini-bars (session + weekly). Hidden until first
			     successful scrape. Click any row to open the full usage tool window. -->
			<Border x:Name="InlineUsagePanel" Grid.Row="3" Margin="0,4,0,2"
			        Padding="6,5"
			        BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"
			        BorderThickness="1"
			        CornerRadius="3"
			        Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
			        Cursor="Hand"
			        Visibility="Collapsed"
			        ToolTip="Click to open the full Claude usage view"
			        MouseLeftButtonUp="InlineUsagePanel_Click">
				<Grid>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="Auto"/>
					</Grid.RowDefinitions>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="Auto" MinWidth="100"/>
						<ColumnDefinition Width="*"/>
						<ColumnDefinition Width="Auto"/>
					</Grid.ColumnDefinitions>

					<!-- Session row -->
					<StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,0">
						<TextBlock x:Name="InlineSessionLabel" Text="Sessão atual"
						           FontSize="11" Opacity="0.95"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
						<TextBlock x:Name="InlineSessionReset" Text=""
						           FontSize="10" Opacity="0.65"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
					</StackPanel>
					<ProgressBar x:Name="InlineSessionBar" Grid.Row="0" Grid.Column="1"
					             Height="8" Minimum="0" Maximum="100" Value="0"
					             Foreground="#3886E5" Background="#2A2A2A" BorderBrush="#606060" BorderThickness="1"
					             VerticalAlignment="Center"/>
					<TextBlock x:Name="InlineSessionPct" Grid.Row="0" Grid.Column="2"
					           Text="0%" FontSize="11" Margin="8,0,0,0"
					           VerticalAlignment="Center" MinWidth="36" TextAlignment="Right"
					           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>

					<!-- Weekly limit row -->
					<StackPanel Grid.Row="1" Grid.Column="0" Margin="0,4,8,0">
						<TextBlock x:Name="InlineWeeklyLabel" Text="Weekly limit"
						           FontSize="11" Opacity="0.95"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
						<TextBlock x:Name="InlineWeeklyReset" Text=""
						           FontSize="10" Opacity="0.65"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
					</StackPanel>
					<ProgressBar x:Name="InlineWeeklyBar" Grid.Row="1" Grid.Column="1"
					             Height="8" Minimum="0" Maximum="100" Value="0"
					             Foreground="#3886E5" Background="#2A2A2A" BorderBrush="#606060" BorderThickness="1"
					             Margin="0,4,0,0" VerticalAlignment="Center"/>
					<TextBlock x:Name="InlineWeeklyPct" Grid.Row="1" Grid.Column="2"
					           Text="0%" FontSize="11" Margin="8,4,0,0"
					           VerticalAlignment="Center" MinWidth="36" TextAlignment="Right"
					           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
					<!-- Extra usage row (hidden until extra-usage is active) -->
					<StackPanel x:Name="InlineExtraUsageStack" Grid.Row="2" Grid.Column="0" Margin="0,4,8,0" Visibility="Collapsed">
						<TextBlock x:Name="InlineExtraUsageSpent" Text="Extra usage"
						           FontSize="11" Opacity="0.95"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
						<TextBlock x:Name="InlineExtraUsageReset" Text=""
						           FontSize="10" Opacity="0.65"
						           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"/>
					</StackPanel>
					<ProgressBar x:Name="InlineExtraUsageBar" Grid.Row="2" Grid.Column="1"
					             Height="8" Minimum="0" Maximum="100" Value="0"
					             Foreground="#3886E5" Background="#2A2A2A" BorderBrush="#606060" BorderThickness="1"
					             Margin="0,4,0,0" VerticalAlignment="Center"
					             Visibility="Collapsed"/>
					<TextBlock x:Name="InlineExtraUsagePct" Grid.Row="2" Grid.Column="2"
					           Text="0%" FontSize="11" Margin="8,4,0,0"
					           VerticalAlignment="Center" MinWidth="36" TextAlignment="Right"
					           Foreground="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowTextKey}}"
					           Visibility="Collapsed"/>
				</Grid>
			</Border>
		</Grid>

		<!-- Resizable Splitter -->
		<GridSplitter x:Name="MainGridSplitter"
                      Grid.Row="1"
                      Height="4"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBorderKey}}"
                      ShowsPreview="True"
                      ResizeDirection="Rows"
                      ResizeBehavior="PreviousAndNext"
                      Cursor="SizeNS"
                      DragCompleted="MainGridSplitter_DragCompleted"/>

		<!-- Embedded Terminal -->
		<GroupBox Grid.Row="2"
                  Margin="6"
                  Foreground="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                  Background="{DynamicResource {x:Static vsshell:VsBrushes.ToolWindowBackgroundKey}}"
                  BorderBrush="{DynamicResource {x:Static vsshell:VsBrushes.WindowTextKey}}"
                  BorderThickness="1"
                  Style="{StaticResource SingleBorderGroupBoxStyle}"
                  x:Name="TerminalGroupBox">
			<GroupBox.Header>
				<TextBlock Text="Claude Code" Opacity="0.93"/>
			</GroupBox.Header>
			<wf:WindowsFormsHost x:Name="TerminalHost"/>
		</GroupBox>
	</Grid>
</UserControl>
